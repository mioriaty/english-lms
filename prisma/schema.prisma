generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  isAdmin      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  submissions  Submission[]
  comments     LectureComment[]
}

model Assignment {
  id               String       @id @default(cuid())
  title            String
  description      String?
  image            String?
  content          Json
  isActive         Boolean      @default(true)
  timeLimitSeconds Int?
  createdAt        DateTime     @default(now())
  submissions      Submission[]
}

model Lecture {
  id          String           @id @default(cuid())
  title       String
  content     String
  pdfUrl      String?
  isPublished Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  comments    LectureComment[]
}

model LectureComment {
  id                 String           @id @default(cuid())
  content            String
  mentionedUsernames String[]         @default([])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  lectureId String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Self-referential: 1 level only (replies to top-level comments)
  parentId String?
  parent   LectureComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  LectureComment[] @relation("CommentReplies")

  @@index([lectureId])
  @@index([authorId])
  @@index([parentId])
}

model Submission {
  id           String     @id @default(cuid())
  score        Float
  details      Json
  submittedAt  DateTime   @default(now())
  feedback     String?
  feedbackAt   DateTime?
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([assignmentId])
}
